@inject TemplatePluginState PluginState

<MudPaper Class="pa-4" Outlined="true">
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h6">Template Plugin</MudText>
            <MudIcon Icon="@Icons.Material.Filled.Extension" Color="Color.Primary" />
        </MudStack>
        <MudText Typo="Typo.body2">
            Dashboard contribution placeholder.
        </MudText>
        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">
            Refreshes: @PluginState.RefreshCount
        </MudChip>
        <MudButton Href="/template-plugin"
                   Variant="Variant.Outlined"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.OpenInNew">
            Open
        </MudButton>
    </MudStack>
</MudPaper>
