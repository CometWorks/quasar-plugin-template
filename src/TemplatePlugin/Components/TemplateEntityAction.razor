@inject ISnackbar Snackbar

<MudTooltip Text="@TooltipText">
    <MudIconButton Icon="@Icons.Material.Filled.Extension"
                   Color="Color.Secondary"
                   Size="Size.Small"
                   Disabled="@(!CanViewEntity)"
                   OnClick="HandleClick" />
</MudTooltip>

@code
{
    [Parameter]
    public string? AgentId { get; set; }

    [Parameter]
    public string? ServerName { get; set; }

    [Parameter]
    public long EntityId { get; set; }

    [Parameter]
    public string? EntityType { get; set; }

    [Parameter]
    public string? EntitySubType { get; set; }

    [Parameter]
    public string? EntityDisplayName { get; set; }

    [Parameter]
    public ulong? OwnerSteamId { get; set; }

    [Parameter]
    public bool CanViewEntity { get; set; }

    private string TooltipText => CanViewEntity
        ? "Template entity action"
        : "Entity is not viewable";

    private void HandleClick()
    {
        var name = string.IsNullOrWhiteSpace(EntityDisplayName)
            ? $"Entity {EntityId}"
            : EntityDisplayName;
        var server = string.IsNullOrWhiteSpace(ServerName)
            ? AgentId ?? "unknown server"
            : ServerName;

        Snackbar.Add($"{name} on {server}: replace this action with plugin logic.", Severity.Info);
    }
}
